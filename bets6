	sound.Volume = 1
	sound.Parent = frame
	
	-- 💡 Globalna funkcja do pokazywania powiadomień
	function _G.Notify(message, duration)
		duration = duration or 5 -- domyślnie 5 sekund, jeśli nie podano
	
		textLabel.Text = message
		frame.Visible = true
	
		-- 🔊 Dźwięk startu
		sound:Play()
	
		-- 🔹 Rozszerzenie ramki (od środka)
		local expandTween = TweenService:Create(
			frame,
			TweenInfo.new(tweenTime, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
			{Size = originalSize}
		)
		expandTween:Play()
		expandTween.Completed:Wait()
	
		-- 🔹 Pokazanie tekstu
		textLabel.Visible = true
	
		-- 🔹 Reset paska
		progressBar.Size = UDim2.new(1, 0, 0, 4)
		progressBar.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
	
		-- 🔹 Cofanie paska w czasie trwania
		local barTween = TweenService:Create(
			progressBar,
			TweenInfo.new(duration, Enum.EasingStyle.Linear),
			{Size = UDim2.new(0, 0, 0, 4)}
		)
		barTween:Play()
	
		-- 🔹 Zmiana koloru paska w czasie
		local elapsed = 0
		local conn
		conn = RunService.Heartbeat:Connect(function(dt)
			elapsed += dt
			local progress = math.clamp(elapsed / duration, 0, 1)
			local color
			if progress < 0.5 then
				local t = progress * 2
				color = Color3.new(1 * t, 1, 0)
			else
				local t = (progress - 0.5) * 2
				color = Color3.new(1, 1 - t, 0)
			end
			progressBar.BackgroundColor3 = color
			if progress >= 1 then
				conn:Disconnect()
			end
		end)
	
		-- 🔹 Czekaj do końca czasu trwania
		task.wait(duration)
	
		-- 🔹 Ukrycie tekstu
		textLabel.Visible = false
	
		-- 🔹 Zwinięcie ramki (do środka)
		local collapseTween = TweenService:Create(
			frame,
			TweenInfo.new(tweenTime, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
			{Size = collapsedSize}
		)
		collapseTween:Play()
		collapseTween.Completed:Wait()
	
		frame.Visible = false
	end
	
