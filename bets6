local function EYZN_fake_script() -- CloseButton.LocalScript 
	local script = Instance.new('LocalScript', CloseButton)

	-- Odwołania do elementów GUI
	local button = script.Parent
	local frame = button.Parent.Frame
	
	-- Ustawienia animacji
	local TweenService = game:GetService("TweenService")
	local tweenTime = 0.3  -- czas trwania animacji (w sekundach)
	
	-- Zmienna stanu (czy GUI jest widoczne)
	local isVisible = true
	
	-- Funkcja do animacji widoczności
	local function toggleFrame()
		if isVisible then
			-- Animacja zanikania
			local tween = TweenService:Create(
				frame,
				TweenInfo.new(tweenTime, Enum.EasingStyle.Sine, Enum.EasingDirection.Out),
				{BackgroundTransparency = 1}
			)
			tween:Play()
			tween.Completed:Connect(function()
				frame.Visible = false
			end)
		else
			frame.Visible = true
			-- Animacja pojawiania
			local tween = TweenService:Create(
				frame,
				TweenInfo.new(tweenTime, Enum.EasingStyle.Sine, Enum.EasingDirection.Out),
				{BackgroundTransparency = 0.3}
			)
			tween:Play()
		end
	
		-- Zmiana stanu
		isVisible = not isVisible
	end
	
	-- Podłączenie przycisku
	button.MouseButton1Click:Connect(toggleFrame)
	
end
