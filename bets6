		StarterGui:SetCore("SendNotification", {
			Title = "Zakup premium",
			Text = "Czy zgadzasz się na teleportację?",
			Button1 = "Tak",
			Button2 = "Nie",
			Callback = callback,
			Duration = 10
		})
	end)
