				table.sort(out)
				return out
			end
	
			-- Globalna funkcja odświeżająca listę przycisków (możesz wywołać z innych miejsc)
			function refreshFileListUI()
				-- usuń stare przyciski (wszystko oprócz wzorca i UIListLayout)
				for _, child in ipairs(scrolling:GetChildren()) do
					if child ~= guzikTemplate and not child:IsA("UIListLayout") then
						child:Destroy()
					end
				end
	
				-- pobierz pliki
				local files = {}
				pcall(function() files = listScriptFiles() end)
	
				-- jeśli brak plików — opcjonalnie pokaż placeholder
				if #files == 0 then
					-- możemy dodać migawkę "Brak skryptów"
					local lbl = Instance.new("TextLabel")
					lbl.Size = UDim2.new(1, -8, 0, 28)
					lbl.BackgroundTransparency = 1
					lbl.TextColor3 = Color3.new(1,1,1)
					lbl.Font = Enum.Font.SourceSans
					lbl.TextSize = 14
					lbl.Text = "Brak zapisanych skryptów"
					lbl.Parent = scrolling
					return
				end
	
				-- tworzenie przycisków z katalogu
				for i, filename in ipairs(files) do
					local clone = guzikTemplate:Clone()
					clone.Name = filename
					-- Guzik1 był ImageButton/TextButton — ustawiamy tekst
					if clone:IsA("TextButton") or clone:IsA("TextLabel") then
						clone.Text = filename
						clone.TextColor3 = Color3.fromRGB(0,0,0)
						clone.TextScaled = true
					else
						-- jeśli to ImageButton, dodaj TextLabel wewnątrz
						local tl = clone:FindFirstChildWhichIsA("TextLabel") or Instance.new("TextLabel", clone)
						tl.Size = UDim2.new(1,0,1,0)
						tl.BackgroundTransparency = 1
						tl.Text = filename
						tl.TextScaled = true
						tl.TextColor3 = Color3.new(0,0,0)
					end
					clone.Parent = scrolling
					clone.Visible = true
					clone.LayoutOrder = i
	
					-- Click: wczytaj plik do ExecutorTextBox
					clone.MouseButton1Click:Connect(function()
						local path = scriptsFolder.."/"..filename
						if type(isfile) == "function" and isfile(path) then
							local ok, content = pcall(function() return readfile(path) end)
							if ok and content then
								executorTextBox.Text = content
							else
								-- komunikat błądu (jeśli masz funkcję notify użyj jej)
								warn("[ScriptsLoader] Nie można odczytać pliku: "..tostring(filename))
							end
						else
							warn("[ScriptsLoader] Plik nie istnieje: "..tostring(path))
							-- odśwież listę bo plik mógł zostać usunięty
							refreshFileListUI()
						end
					end)
				end
			end
	
			-- expose also globally (ułatwia wywołanie z modal save)
			_G.refreshFileListUI = refreshFileListUI
	
			-- pierwszy refresh na start (z drobnym opóźnieniem żeby GUI był załadowany)
			task.defer(function()
				-- upewnij się, że foldery istnieją (jeśli exploit obsługuje)
				if type(isfolder) == "function" and type(makefolder) == "function" then
					if not isfolder(baseFolder) then pcall(makefolder, baseFolder) end
					if not isfolder(scriptsFolder) then pcall(makefolder, scriptsFolder) end
				end
				-- poczekaj chwilę i odśwież
				task.wait(0.05)
				pcall(refreshFileListUI)
			end)
		end
	
	end
	
	-- Podłączenie zdarzeń
	button.MouseEnter:Connect(onMouseEnter)
	button.MouseLeave:Connect(onMouseLeave)
	button.MouseButton1Click:Connect(onMouseClick)
end
