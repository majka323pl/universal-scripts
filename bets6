local function HEFTAGJ_fake_script() -- Executor.LocalScript 
	local script = Instance.new('LocalScript', Executor)

	-- Executor - poprawiony LocalScript
	-- Wkleić jako LocalScript w obiekcie "Executor"
	
	local UserInputService = game:GetService("UserInputService")
	local Players = game:GetService("Players")
	local player = Players.LocalPlayer
	
	local executor = script.Parent
	if not executor then
		warn("Ten skrypt musi być child 'Executor' frame")
		return
	end
	
	-- Znajdź elementy GUI (dostosowuje się do kilku możliwych nazw)
	local scriptTab = executor:FindFirstChild("Script tab") or executor
	local scriptsFrame = scriptTab:FindFirstChild("Scripts") or executor:FindFirstChild("ScrollingFrame") or executor:FindFirstChild("Scripts")
	local template = nil
	if scriptsFrame then
		template = scriptsFrame:FindFirstChild("Guzik1") or scriptsFrame:FindFirstChild("Guzik1_3") or scriptsFrame:FindFirstChildWhichIsA("TextButton")
	end
	local codeBox = executor.ExecutorScrollingFrame:FindFirstChild("ExecutorTextBox") or executor.ExecutorScrollingFrame:FindFirstChildWhichIsA("TextBox")
	local errorLabel = executor:FindFirstChild("ErrorLabel") or executor:FindFirstChildWhichIsA("TextLabel")
	
	-- przyciski z Script tab (różne nazwy obsługiwane)
	local saveGuiButton = scriptTab:FindFirstChild("SaveFile") or scriptTab:FindFirstChild("Save")
	local btnExecute = scriptTab:FindFirstChild("Execute")
	local btnClear = scriptTab:FindFirstChild("ClearExecTextBox") or scriptTab:FindFirstChild("Clear")
	local btnCopy = scriptTab:FindFirstChild("CopyToClipboard") or scriptTab:FindFirstChild("Copy")
	local btnPaste = scriptTab:FindFirstChild("PasteFromClipboard") or scriptTab:FindFirstChild("Paste")
	local btnExecFromClipboard = scriptTab:FindFirstChild("ExecuteFromClipboard") -- preserved
	local btnRename = scriptTab:FindFirstChild("Rename")
	local btnDelete = scriptTab:FindFirstChild("Delete")
	
	-- FS (exploit)
	local baseFolder = "UniversalScripts"
	local scriptsFolder = baseFolder .. "/SavedScripts"
	
	-- Notify helper (use _G.Notify if available)
	local function Notify(msg)
		if type(_G) == "table" and type(_G.Notify) == "function" then
			pcall(function() _G.Notify(msg, 1) end)
			return
		end
		if errorLabel then
			pcall(function() errorLabel.Text = tostring(msg) end)
			return
		end
		warn(msg)
	end
	
	-- Safe FS wrappers
	local function safeIsFolder(p)
		if type(isfolder) ~= "function" then return false end
		local ok, res = pcall(isfolder, p)
		return ok and res
	end
	local function safeMakeFolder(p)
		if type(makefolder) ~= "function" then return false end
		local ok = pcall(makefolder, p)
		return ok
	end
	local function safeListFiles(p)
		if type(listfiles) ~= "function" then return {} end
		local ok, res = pcall(listfiles, p)
		if ok and type(res) == "table" then return res end
		return {}
	end
	local function safeIsFile(p)
		if type(isfile) ~= "function" then return false end
		local ok, res = pcall(isfile, p)
		return ok and res
	end
	local function safeReadFile(p)
		if type(readfile) ~= "function" then return nil end
		local ok, res = pcall(readfile, p)
		if ok then return res end
		return nil
	end
	local function safeWriteFile(p, content)
		if type(writefile) ~= "function" then return false end
		local ok = pcall(writefile, p, content)
		return ok
	end
	local function safeDeleteFile(p)
		if type(delfile) ~= "function" then return false end
		local ok = pcall(delfile, p)
		return ok
	end
	
	-- ensure folders
	if type(isfolder) == "function" and type(makefolder) == "function" then
		if not safeIsFolder(baseFolder) then pcall(safeMakeFolder, baseFolder) end
		if not safeIsFolder(scriptsFolder) then pcall(safeMakeFolder, scriptsFolder) end
	end
	
	-- unique filename
	local function makeUniqueFilename(name)
		if not name or name == "" then name = "script_"..tostring(os.time())..".lua" end
		if not name:match("%.lua$") then name = name..".lua" end
		local path = scriptsFolder.."/"..name
		if not safeIsFile(path) then return name end
		local base = name:gsub("%.lua$", "")
		local i = 1
		while true do
			local cand = base.."_copy"..i..".lua"
			if not safeIsFile(scriptsFolder.."/"..cand) then return cand end
			i = i + 1
		end
	end
	_G.makeUniqueFilename = makeUniqueFilename
	
	-- UI helpers
	local function ensureListLayout(frame)
		local layout = frame:FindFirstChildOfClass("UIListLayout")
		if not layout then
			layout = Instance.new("UIListLayout", frame)
			layout.Padding = UDim.new(0,6)
			layout.SortOrder = Enum.SortOrder.LayoutOrder
		end
		return layout
	end
	
	-- template handling
	if template then
		pcall(function() template.Visible = false end)
	else
		Notify("Brak wzorca przycisku (Guzik1). Lista plików nie będzie dostępna.")
	end
	
	-- selected file state
	local selectedFile = nil
	local selectedButton = nil
	
	local function clearSelectionVisual()
		for _,c in ipairs(scriptsFrame:GetChildren()) do
			if c:IsA("TextButton") and c ~= template then
				-- restore to template color if possible
				if template and template:IsA("TextButton") then
					c.BackgroundColor3 = template.BackgroundColor3
					c.TextColor3 = template.TextColor3 or c.TextColor3
				else
					c.BackgroundColor3 = Color3.fromRGB(60,60,60)
					c.TextColor3 = Color3.new(1,1,1)
				end
			end
		end
		selectedFile = nil
		selectedButton = nil
	end
	
	-- refresh list (fixes placeholder duplication and selection)
	local function refreshFileListUI()
		if not scriptsFrame then
			Notify("Brak frames dla listy skryptów.")
			return
		end
	
		-- destroy old clones & placeholders (keep template & UIListLayout)
		for _, child in ipairs(scriptsFrame:GetChildren()) do
			if child ~= template and not child:IsA("UIListLayout") then
				child:Destroy()
			end
		end
	
		ensureListLayout(scriptsFrame)
	
		local raw = safeListFiles(scriptsFolder)
		local files = {}
		for _, full in ipairs(raw) do
			local name = full:match("([^/\\]+)$")
			if name and name:match("%.lua$") then table.insert(files, name) end
		end
		table.sort(files)
	
		if #files == 0 then
			if template then template.Visible = false end
			local lbl = Instance.new("TextLabel")
			lbl.Size = UDim2.new(1, -8, 0, 28)
			lbl.BackgroundTransparency = 1
			lbl.Text = "Brak zapisanych skryptów."
			lbl.TextColor3 = Color3.fromRGB(200,200,200)
			lbl.Font = Enum.Font.SourceSans
			lbl.TextScaled = true
			lbl.Parent = scriptsFrame
			return
		end
	
		for i, filename in ipairs(files) do
			local btn
			if template and template:IsA("TextButton") then
				btn = template:Clone()
			else
				btn = Instance.new("TextButton")
				btn.Size = UDim2.new(1, -10, 0, 28)
				btn.BackgroundColor3 = template and template.BackgroundColor3 or Color3.fromRGB(60,60,60)
				btn.TextColor3 = template and template.TextColor3 or Color3.new(1,1,1)
				btn.Font = Enum.Font.SourceSans
				btn.TextSize = 15
				Instance.new("UICorner", btn)
			end
	
			btn.Name = "FileBtn_"..i
			btn.Text = filename
			btn.Visible = true
			btn.Parent = scriptsFrame
			btn.LayoutOrder = i
			btn.TextScaled = true
	
			-- click handler: set selection and load content
			btn.MouseButton1Click:Connect(function()
				-- visual selection
				clearSelectionVisual()
				if btn:IsA("TextButton") then
					btn.BackgroundColor3 = Color3.fromRGB(90,90,90)
					if template and template.TextColor3 then
						btn.TextColor3 = template.TextColor3
					end
				end
				selectedFile = filename
				selectedButton = btn
	
				-- load file content
				local path = scriptsFolder.."/"..filename
				if safeIsFile(path) then
					local content = safeReadFile(path)
					if content and codeBox then
						codeBox.Text = content
						Notify("Wczytano: "..filename)
					else
						Notify("Błąd wczytywania: "..filename)
					end
				else
					Notify("Plik nie istnieje: "..filename)
					selectedFile = nil
					selectedButton = nil
					refreshFileListUI()
				end
			end)
	
			-- right-click quick execute (kept)
			btn.MouseButton2Click:Connect(function()
				local path = scriptsFolder.."/"..filename
				if safeIsFile(path) then
					local content = safeReadFile(path)
					if content then
						local ok, err = pcall(function()
							local fn, loadErr = loadstring(content)
							if not fn then error(loadErr) end
							fn()
						end)
						if not ok then Notify("Błąd wykonania: "..tostring(err)) else Notify("Wykonano: "..filename) end
					end
				end
			end)
		end
	
		if template then template.Visible = false end
	end
	
	_G.refreshFileListUI = refreshFileListUI
	
	-- BUTTON logic
	
	-- Execute
	if btnExecute then
		if not btnExecute:GetAttribute("connected_exec") then
			btnExecute.MouseButton1Click:Connect(function()
				if not codeBox then Notify("Brak pola edytora"); return end
				local code = codeBox.Text or ""
				if code == "" then Notify("Brak kodu do uruchomienia"); return end
				local ok, err = pcall(function()
					local fn, loadErr = loadstring(code)
					if not fn then error(loadErr) end
					fn()
				end)
				if not ok then Notify("Błąd: "..tostring(err)) else Notify("Wykonano kod") end
			end)
			btnExecute:SetAttribute("connected_exec", true)
		end
	end
	
	-- Clear
	if btnClear then
		if not btnClear:GetAttribute("connected_clear") then
			btnClear.MouseButton1Click:Connect(function()
				if codeBox then codeBox.Text = "" end
				Notify("Wyczyszczono edytor")
			end)
			btnClear:SetAttribute("connected_clear", true)
		end
	end
	
	-- Copy
	if btnCopy then
		if not btnCopy:GetAttribute("connected_copy") then
			btnCopy.MouseButton1Click:Connect(function()
				if not codeBox then Notify("Brak edytora"); return end
				local txt = codeBox.Text or ""
				if type(setclipboard) == "function" then
					pcall(function() setclipboard(txt) end)
					Notify("Skopiowano do schowka")
				else
					Notify("setclipboard() nie dostępne")
				end
			end)
			btnCopy:SetAttribute("connected_copy", true)
		end
	end
	
	-- Paste
	if btnPaste then
		if not btnPaste:GetAttribute("connected_paste") then
			btnPaste.MouseButton1Click:Connect(function()
				local clip = nil
				if type(getclipboard) == "function" then
					local ok, res = pcall(getclipboard)
					if ok then clip = res end
				elseif type(readclipboard) == "function" then
					local ok, res = pcall(readclipboard)
					if ok then clip = res end
				end
				if clip and codeBox then codeBox.Text = tostring(clip); Notify("Wklejono ze schowka") else Notify("Schowek niedostępny") end
			end)
