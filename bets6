	function _G.AnimateAndFunc(button, callback)
		if not button then return end
	
		local expandPixels = 10
		local tweenDuration = 0.2
	
		-- Inicjalizacja komponentów
		local uiStroke = button:FindFirstChildWhichIsA("UIStroke")
		local tip = button:FindFirstChild("Tip")
	
		-- Zapamiętywanie stanu początkowego
		local originalSize = button.Size
		local originalPosition = button.Position
		local originalStrokeThickness = uiStroke and uiStroke.Thickness or 2.5
		local hoverStrokeThickness = 4
		local originalStrokeColor = uiStroke and uiStroke.Color or Color3.fromRGB(0, 0, 0)
		local hoverStrokeColor = Color3.fromRGB(0, 0, 0)
	
		local originalChildSizes = {}
		for _, child in ipairs(button:GetChildren()) do
			if child:IsA("TextLabel") or child:IsA("ImageLabel") or child:IsA("TextButton") then
				originalChildSizes[child] = child.Size
			end
		end
	
		-- Tworzenie dźwięków
		local hoverSound = Instance.new("Sound")
		hoverSound.SoundId = "rbxassetid://75250247593685"
		hoverSound.Volume = 1
		hoverSound.Parent = button
	
		local clickSound = Instance.new("Sound")
		clickSound.SoundId = "rbxassetid://535716488"
		clickSound.Volume = 1
		clickSound.Parent = button
	
		-- Setup Tip
		if tip then
			if tip:IsA("TextLabel") then tip.TextTransparency = 1
			elseif tip:IsA("Frame") or tip:IsA("ImageLabel") then tip.BackgroundTransparency = 1 end
			tip.Visible = false
		end
	
		-- Event: Hover Enter
		button.MouseEnter:Connect(function()
			local newSize = UDim2.new(originalSize.X.Scale, originalSize.X.Offset + expandPixels * 2, originalSize.Y.Scale, originalSize.Y.Offset + expandPixels * 2)
			local newPosition = UDim2.new(originalPosition.X.Scale, originalPosition.X.Offset - expandPixels, originalPosition.Y.Scale, originalPosition.Y.Offset - expandPixels)
	
			button:TweenSizeAndPosition(newSize, newPosition, "Out", "Quad", tweenDuration, true)
	
			for child, size in pairs(originalChildSizes) do
				local newChildSize = UDim2.new(size.X.Scale, size.X.Offset + expandPixels, size.Y.Scale, size.Y.Offset + expandPixels)
				child:TweenSize(newChildSize, "Out", "Quad", tweenDuration, true)
			end
	
			if uiStroke then
				uiStroke.Thickness = hoverStrokeThickness
				uiStroke.Color = hoverStrokeColor
			end
	
			hoverSound:Play()
	
			if tip then
				tip.Visible = true
				TweenService:Create(tip, TweenInfo.new(0.3), {
					TextTransparency = tip:IsA("TextLabel") and 0 or nil,
					BackgroundTransparency = (tip:IsA("Frame") or tip:IsA("ImageLabel")) and 0 or nil
				}):Play()
			end
		end)
	
		-- Event: Hover Leave
		button.MouseLeave:Connect(function()
			button:TweenSizeAndPosition(originalSize, originalPosition, "Out", "Quad", tweenDuration, true)
			for child, size in pairs(originalChildSizes) do
				child:TweenSize(size, "Out", "Quad", tweenDuration, true)
			end
	
			if uiStroke then
				uiStroke.Thickness = originalStrokeThickness
				uiStroke.Color = originalStrokeColor
			end
	
			if tip then
				local fade = TweenService:Create(tip, TweenInfo.new(0.3), {
					TextTransparency = tip:IsA("TextLabel") and 1 or nil,
					BackgroundTransparency = (tip:IsA("Frame") or tip:IsA("ImageLabel")) and 1 or nil
				})
				fade:Play()
				fade.Completed:Connect(function() tip.Visible = false end)
			end
		end)
	
		-- Event: Click
		button.MouseButton1Click:Connect(function()
			clickSound:Play()
			if callback then
				callback() 
			end
		end)
	end
	
	-- PRZYKŁAD UŻYCIA
	_G.AnimateAndFunc(script.Parent, function()
		local Players = game:GetService("Players")
		local StarterGui = game:GetService("StarterGui")
