-- Funkcje Executora
Execute.MouseButton1Click:Connect(function()
    local code = ExecutorTextBox.Text
    local success, err = pcall(function()
        loadstring(code)()
    end)
    if not success then
        warn("Błąd skryptu: " .. tostring(err))
    end
end)

