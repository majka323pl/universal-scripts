-- ==========================================
-- LOGIKA DZIAŁANIA (MOBILE & PC)
-- ==========================================

local HttpService = game:GetService("HttpService")

local function Search()
    local text = TextBox.Text
    if text == "" then return end
    
    TextBox:ReleaseFocus()
    if _G.Notify then _G.Notify("Szukanie...", 1) end

    -- Czyszczenie
    for _, child in pairs(ScrollingFrame:GetChildren()) do
        if child:IsA("Frame") and child.Name ~= "Template" then
            child:Destroy()
        end
    end

    local request = http_request or request or (syn and syn.request) or (fluxus and fluxus.request)
    if not request then 
        warn("Brak obsługi HTTP w Twoim executorze.")
        return 
    end

    local url = "https://scriptblox.com/api/script/search?q=" .. HttpService:UrlEncode(text) .. "&mode=free&page=1"
    
    local success, response = pcall(function()
        return request({Url = url, Method = "GET"})
    end)

    if success and response.StatusCode == 200 then
        local data = HttpService:JSONDecode(response.Body)
        
        for _, s in pairs(data.result.scripts) do
            local clone = Template:Clone()
            clone.Parent = ScrollingFrame
            clone.Visible = true
            clone.Title.Text = s.title
            
            -- Wykonaj
            clone.Execute.Activated:Connect(function()
                local f, err = loadstring(s.script)
                if f then f() else warn(err) end
            end)
            
            -- Kopiuj
            clone.Copy.Activated:Connect(function()
                setclipboard(s.script)
                if _G.Notify then _G.Notify("Skopiowano!", 1) end
            end)
        end
        ScrollingFrame.CanvasSize = UDim2.new(0, 0, 0, UIListLayout.AbsoluteContentSize.Y + 20)
    end
end

-- Podpięcie pod przycisk (Używamy Activated dla Mobile)
TextButton.Activated:Connect(Search)
TextBox.FocusLost:Connect(function(enter) if enter then Search() end end)
