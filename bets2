-- 1. Funkcja wyszukiwania
_G.StartProjectSearch = function()
    local q = TextBox.Text
    if q == "" then return end
    
    for _, v in pairs(Scroll:GetChildren()) do
        if v:IsA("Frame") and v.Name ~= "Template" then v:Destroy() end
    end

    local req = http_request or request or (syn and syn.request)
    local url = "https://scriptblox.com/api/script/search?q=" .. HttpService:UrlEncode(q) .. "&mode=free&page=1"
    
    local success, res = pcall(function() return req({Url = url, Method = "GET"}) end)
    if success and res.StatusCode == 200 then
        local data = HttpService:JSONDecode(res.Body)
        for _, s in pairs(data.result.scripts) do
            local card = Template:Clone()
            card.Parent = Scroll
            card.Visible = true
            card.Title.Text = s.title
            
            card.Execute.Activated:Connect(function() loadstring(s.script)() end)
            card.Copy.Activated:Connect(function() setclipboard(s.script) end)
            
            -- Edytuj: wysyła do Twojego panelu edytora (jeśli masz TextBox w Executorze)
            card.Edit.Activated:Connect(function()
                local ExecutorPanel = MainFrame:FindFirstChild("Executor") -- Zmień nazwę jeśli panel edytora nazywa się inaczej
                if ExecutorPanel then
                    local EditorBox = ExecutorPanel:FindFirstChildOfClass("TextBox") or ExecutorPanel:FindFirstChild("Editor")
                    if EditorBox then
                        EditorBox.Text = s.script
                        Searcher.Visible = false
                        ExecutorPanel.Visible = true
                    end
                end
                setclipboard(s.script) -- Backup do schowka
            end)
        end
        Scroll.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 20)
    end
end

-- 2. Twój kod TWEEN dla BackBtn
local function ApplyTweenLogic(btn)
    local originalSize = btn.Size
    local originalPosition = btn.Position
    local expandPixels = 3

    btn.MouseEnter:Connect(function()
        local newSize = UDim2.new(originalSize.X.Scale, originalSize.X.Offset + expandPixels * 2, originalSize.Y.Scale, originalSize.Y.Offset + expandPixels * 2)
        local newPosition = UDim2.new(originalPosition.X.Scale, originalPosition.X.Offset - expandPixels, originalPosition.Y.Scale, originalPosition.Y.Offset - expandPixels)
        btn:TweenSizeAndPosition(newSize, newPosition, "Out", "Quad", 0.2, true)
    end)

    btn.MouseLeave:Connect(function()
        btn:TweenSizeAndPosition(originalSize, originalPosition, "Out", "Quad", 0.2, true)
    end)

    btn.Activated:Connect(function()
        local Home = MainFrame:FindFirstChild("Home")
        if Home then
            Searcher.Visible = false
            Home.Visible = true
        end
    end)
end
ApplyTweenLogic(BackBtn)

